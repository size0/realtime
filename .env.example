# Server-only secrets. Never prefix these variables with NEXT_PUBLIC_.
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_WORKSPACE_ID=llm-your-workspace-id

# Beijing is the default. Singapore uses ap-southeast-1 and a key from that region.
DASHSCOPE_REGION=cn-beijing

# Optional: qwen3.5-omni-plus-realtime (best quality) or qwen3.5-omni-flash-realtime.
DASHSCOPE_REALTIME_MODEL=qwen3.5-omni-plus-realtime

# Optional canonical origin for same-origin validation in production.
# APP_ORIGIN=https://voice.example.com
