# 复制为 .env.local。所有变量都只允许存在于服务器，禁止使用 NEXT_PUBLIC_ 前缀。
APP_ORIGIN=https://voice.xdw0.cn
APP_DATABASE_FILE=.data/app.sqlite
APP_DATA_FILE=.data/users.json
APP_BACKUP_DIRECTORY=.data/backups

# 每项都要使用不同的随机值。MESSAGE_ENCRYPTION_KEY 必须是32字节Base64或64位Hex。
SESSION_SECRET=replace-with-at-least-32-random-characters
VOICE_WORKER_SECRET=replace-with-another-at-least-32-random-characters
OAUTH_IDENTITY_SECRET=replace-with-another-at-least-32-random-characters
MESSAGE_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# 微信公众号网页授权（snsapi_base）。
WECHAT_LOGIN_ENABLED=true
WECHAT_OFFICIAL_ACCOUNT_APP_ID=wx-your-official-account-app-id
WECHAT_OFFICIAL_ACCOUNT_APP_SECRET=replace-with-rotated-app-secret
WECHAT_OAUTH_REDIRECT_URI=https://voice.xdw0.cn/api/auth/wechat/callback

# 首次启动管理员。创建后修改环境变量不会覆盖数据库中的管理员密码。
ADMIN_USERNAME=admin
ADMIN_DISPLAY_NAME=管理员
ADMIN_PASSWORD=replace-with-a-strong-initial-password

# SenseVoice/FunASR + Qwen3实时TTS。
DASHSCOPE_API_KEY=replace-with-rotated-dashscope-key
VOICE_ASR_MODEL=FunAudioLLM/SenseVoiceSmall
VOICE_VAD_THRESHOLD=0.5
VOICE_MIN_SILENCE_MS=1100
VOICE_SPEECH_PAD_MS=160
VOICE_TTS_MODEL=qwen3-tts-instruct-flash-realtime
VOICE_TTS_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
VOICE_USAGE_REPORT_URL=https://voice.xdw0.cn/api/internal/voice-usage

# 普通倾诉使用的便宜文本模型。
ECONOMY_REASONING_API_KEY=replace-with-rotated-key
ECONOMY_REASONING_BASE_URL=https://llm-your-workspace-id.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
ECONOMY_REASONING_MODEL=qwen3.5-flash
ECONOMY_REASONING_FALLBACK_MODEL=

# 复杂问题与风险内容使用的强模型。
STRONG_REASONING_API_KEY=replace-with-rotated-key
STRONG_REASONING_BASE_URL=https://your-provider.example/v1
STRONG_REASONING_MODEL=your-strong-model
STRONG_REASONING_FALLBACK_MODEL=

# 旧的JSON会在首次启动时备份并迁移。下面两项仅保留旧版回复次数保护。
GUEST_DAILY_CONNECTION_LIMIT=10
GUEST_DAILY_REPLY_LIMIT=50
