# Server-only secrets. Never prefix these variables with NEXT_PUBLIC_.
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_WORKSPACE_ID=llm-your-workspace-id

# Beijing is the default. Singapore uses ap-southeast-1 and a key from that region.
DASHSCOPE_REGION=cn-beijing
DASHSCOPE_REALTIME_MODEL=qwen3.5-omni-plus-realtime

# Text answer model. This provider is independent from the Qwen Realtime voice layer.
REASONING_API_KEY=sk-your-reasoning-provider-key
REASONING_BASE_URL=https://airelvo.cc/v1
REASONING_MODEL=gpt-5.5
REASONING_FALLBACK_MODEL=gpt-5.4

# Login and persistent user store.
SESSION_SECRET=replace-with-at-least-32-random-characters
ADMIN_USERNAME=admin
ADMIN_DISPLAY_NAME=管理员
ADMIN_PASSWORD=replace-with-a-strong-initial-password
APP_DATA_FILE=.data/users.json

# Automatic guest safeguards (per account, reset at midnight Asia/Shanghai).
GUEST_DAILY_CONNECTION_LIMIT=10
GUEST_DAILY_REPLY_LIMIT=50

# Optional canonical origin for same-origin validation in production.
# APP_ORIGIN=https://voice.example.com
