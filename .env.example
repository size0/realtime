# Server-only secrets. Never prefix these variables with NEXT_PUBLIC_.
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_WORKSPACE_ID=llm-your-workspace-id

# Beijing is the default. Singapore uses ap-southeast-1 and a key from that region.
DASHSCOPE_REGION=cn-beijing
DASHSCOPE_REALTIME_MODEL=qwen3.5-omni-flash-realtime

# Economy text model for ordinary treehole chat.
ECONOMY_REASONING_API_KEY=sk-your-dashscope-api-key
ECONOMY_REASONING_BASE_URL=https://llm-your-workspace-id.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
ECONOMY_REASONING_MODEL=qwen3.5-flash
ECONOMY_REASONING_FALLBACK_MODEL=

# Strong text model for complex or high-stakes questions.
# The legacy REASONING_* names remain supported for backward compatibility.
REASONING_API_KEY=sk-your-reasoning-provider-key
REASONING_BASE_URL=https://airelvo.cc/v1
REASONING_MODEL=gpt-5.5
REASONING_FALLBACK_MODEL=gpt-5.4

# Split voice worker. Use a different random secret in production.
VOICE_WORKER_SECRET=replace-with-another-at-least-32-character-random-secret
VOICE_ASR_MODEL=iic/SenseVoiceSmall
VOICE_VAD_THRESHOLD=0.5
VOICE_MIN_SILENCE_MS=1100
VOICE_SPEECH_PAD_MS=160
VOICE_TTS_MODEL=qwen3-tts-instruct-flash-realtime
VOICE_TTS_VOICE=Cherry
VOICE_TTS_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime

# Login and persistent user store.
SESSION_SECRET=replace-with-at-least-32-random-characters
ADMIN_USERNAME=admin
ADMIN_DISPLAY_NAME=管理员
ADMIN_PASSWORD=replace-with-a-strong-initial-password
APP_DATA_FILE=.data/users.json

# Automatic guest safeguards (per account, reset at midnight Asia/Shanghai).
GUEST_DAILY_CONNECTION_LIMIT=10
GUEST_DAILY_REPLY_LIMIT=50

# Canonical origin is required by the split voice worker in production.
APP_ORIGIN=https://voice.example.com
